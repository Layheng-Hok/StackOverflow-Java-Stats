      "comment_id" : 119743572,
      "content_license" : "CC BY-SA 4.0",
      "body" : "I was trying to get selenium with goolechrome + java/maven started so I used brew cask install of the chromedriver when I had this error. Doing this worked for me. If you need to navigate the FINDER app on Mac to specific folders , use SHIFT + COMMAND + G"
    } ],
    "owner" : {
      "account_id" : 17870880,
      "reputation" : 157,
      "user_id" : 12982205,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/9850c58404dca1e093265a9c6faccbb4?s=256&d=identicon&r=PG&f=y&so-version=2",
      "display_name" : "yeqiuuu",
