    "answer_id" : 20899646,
    "question_id" : 5534748,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<p><kbd> Ctrl </kbd> + <kbd>Shift</kbd> + <kbd>C </kbd>. Works great on <strong>.java</strong>, <strong>.xhtml</strong>, <strong>.properties</strong> and maybe on others but I only tested these ones. Can comment single or multiple lines.</p>\n"
  }, {
    "owner" : {
      "account_id" : 3657733,
      "reputation" : 485,
      "user_id" : 3048270,
      "user_type" : "registered",
      "profile_image" : "https://i.sstatic.net/sr64B.jpg?s=256",
