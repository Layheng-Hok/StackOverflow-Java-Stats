        "display_name" : "arcynum",
        "link" : "https://stackoverflow.com/users/891213/arcynum"
      },
      "edited" : false,
      "score" : 0,
      "creation_date" : 1484612945,
      "post_id" : 40801363,
      "comment_id" : 70571515,
      "content_license" : "CC BY-SA 3.0",
      "body" : "I actually think this is the best way to think about the solution. It makes more sense to make things you need private and control them from the object itself."
    } ],
