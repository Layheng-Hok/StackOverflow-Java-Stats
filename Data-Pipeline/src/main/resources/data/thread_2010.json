    "answer_id" : 53112491,
    "question_id" : 9112900,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>set variable as </p>\n\n<p>@JsonIgnore</p>\n\n<p>This allows variable to get skipped by json serializer</p>\n"
  } ],
