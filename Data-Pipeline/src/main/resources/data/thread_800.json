      "reputation" : 16448,
      "user_id" : 2326914,
      "user_type" : "registered",
      "accept_rate" : 33,
      "profile_image" : "https://www.gravatar.com/avatar/5be766827c5f7d3c077e92f75b7f9104?s=256&d=identicon&r=PG",
      "display_name" : "Rog&#233;rio",
