      "creation_date" : 1350630039,
      "post_id" : 12960618,
      "comment_id" : 17585548,
      "content_license" : "CC BY-SA 3.0",
      "body" : "Yes. Tools like bean utilities count on the word <b>is</b> to find boolean getters."
    } ],
    "owner" : {
