    "question_id" : 7326155,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>add layout_gravity and gravity with center value on TextView</p>\n\n<pre><code>&lt;TextView\n    android:text=\"welcome text\"\n    android:layout_width=\"match_parent\"\n    android:layout_height=\"match_parent\"\n    android:layout_gravity=\"center\"\n    android:gravity=\"center\"\n    /&gt;\n</code></pre>\n"
  }, {
    "owner" : {
      "account_id" : 13180260,
      "reputation" : 1069,
      "user_id" : 9519872,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/9123da91b979cd50dfac16ab112b1d11?s=256&d=identicon&r=PG",
      "display_name" : "Dinith",
