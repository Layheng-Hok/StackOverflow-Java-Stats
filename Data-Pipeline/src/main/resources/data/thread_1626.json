    },
    "is_accepted" : false,
    "score" : 2,
    "last_activity_date" : 1680600936,
    "creation_date" : 1680600936,
    "answer_id" : 75927794,
    "question_id" : 69696321,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>Below process worked for me: File -&gt; Project Structure -&gt; Platform Settings -&gt; SDKs -&gt; <em>jdk-17.0.5</em>[for me](ADD JDK Required version either from disk or download it)</p>\n"
  }, {
