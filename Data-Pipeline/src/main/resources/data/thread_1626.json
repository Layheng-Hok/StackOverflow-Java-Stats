    "owner" : {
      "account_id" : 2691023,
      "reputation" : 17967,
      "user_id" : 2324388,
      "user_type" : "registered",
      "accept_rate" : 41,
      "profile_image" : "https://i.sstatic.net/RdjjJ.jpg?s=256",
      "display_name" : "Marian Kl&#252;hspies",
      "link" : "https://stackoverflow.com/users/2324388/marian-kl%c3%bchspies"
    },
    "is_accepted" : false,
