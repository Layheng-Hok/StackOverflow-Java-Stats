    "question_id" : 5725892,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<pre><code>public static String capitalize(String str){\n        String[] inputWords = str.split(\" \");\n        String outputWords = \"\";\n        for (String word : inputWords){\n            if (!word.isEmpty()){\n                outputWords = outputWords + \" \"+StringUtils.capitalize(word);\n            }\n        }\n        return outputWords;\n    }\n</code></pre>\n"
  }, {
    "owner" : {
      "account_id" : 2026540,
      "reputation" : 2022,
      "user_id" : 1811356,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/38c6d672e1975b8ead85528142b85a65?s=256&d=identicon&r=PG",
      "display_name" : "Hardian",
