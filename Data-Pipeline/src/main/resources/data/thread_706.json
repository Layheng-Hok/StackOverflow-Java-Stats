    "owner" : {
      "account_id" : 159083,
      "reputation" : 15849,
      "user_id" : 378151,
      "user_type" : "registered",
      "accept_rate" : 74,
      "profile_image" : "https://www.gravatar.com/avatar/0e548cf2f32966f42bd0d1e07b4d8108?s=256&d=identicon&r=PG",
      "display_name" : "Snekse",
      "link" : "https://stackoverflow.com/users/378151/snekse"
