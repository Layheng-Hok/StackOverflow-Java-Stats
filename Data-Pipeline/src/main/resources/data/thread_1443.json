        "user_type" : "registered",
        "accept_rate" : 62,
        "profile_image" : "https://www.gravatar.com/avatar/84a0e8aa370e949feeaa7c5c153a3be9?s=256&d=identicon&r=PG",
        "display_name" : "xeruf",
        "link" : "https://stackoverflow.com/users/6723250/xeruf"
