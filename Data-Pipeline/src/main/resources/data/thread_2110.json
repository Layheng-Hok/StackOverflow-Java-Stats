      "comment_id" : 76443352,
      "content_license" : "CC BY-SA 3.0",
      "body" : "Whether an <code>if</code> is faster than a <code>%</code> depends on your CPU and the data you feed it, due to branch prediction--<code>if</code>s are faster if the condition has a predictable pattern."
    }, {
      "owner" : {
        "account_id" : 700283,
        "reputation" : 1687,
        "user_id" : 589907,
        "user_type" : "registered",
        "profile_image" : "https://www.gravatar.com/avatar/e614fe723343cb77d439ee8caf3c4b26?s=256&d=identicon&r=PG",
        "display_name" : "Scott Carey",
