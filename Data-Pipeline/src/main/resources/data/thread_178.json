      "post_id" : 33753519,
      "comment_id" : 73985479,
      "content_license" : "CC BY-SA 3.0",
      "body" : "look in to source code      public interface Autowired {  \t/** \t * Declares whether the annotated dependency is required. \t */ \tboolean required() default true;      }      public interface Inject {}"
    } ],
