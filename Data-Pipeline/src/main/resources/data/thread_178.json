      },
      "edited" : false,
      "score" : 0,
      "creation_date" : 1643975452,
      "post_id" : 25380286,
      "comment_id" : 125487709,
      "content_license" : "CC BY-SA 4.0",
      "body" : "By writing @Autowired(required = false) you can finish the initialization of your component even if Spring was unable to wire (inject) the member. @Inject will throw an exception in such case, without the opportunity to continue with construction/injection."
    } ],
    "owner" : {
      "account_id" : 201558,
      "reputation" : 21234,
      "user_id" : 448078,
      "user_type" : "registered",
      "accept_rate" : 61,
      "profile_image" : "https://i.sstatic.net/i23wc.png?s=256",
