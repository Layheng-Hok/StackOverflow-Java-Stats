    "body" : "<pre><code>if(map.get(key) != null || (map.get(key) == null &amp;&amp; map.containsKey(key)))\n</code></pre>\n"
  }, {
    "owner" : {
      "account_id" : 100270,
      "reputation" : 132415,
      "user_id" : 270371,
      "user_type" : "registered",
      "accept_rate" : 33,
      "profile_image" : "https://i.sstatic.net/LSTUa.png?s=256",
      "display_name" : "davidxxx",
