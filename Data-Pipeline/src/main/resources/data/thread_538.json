      "comment_id" : 137219837,
      "content_license" : "CC BY-SA 4.0",
      "body" : "Neither of these reasons are valid: (1) Spring itself advises against using Field injection, so don&#39;t do that (2) You can&#39;t call the constructor multiple times in a single instances lifecycle, as other folks pointed out."
    } ],
    "owner" : {
      "account_id" : 70258,
      "reputation" : 599026,
      "user_id" : 203907,
      "user_type" : "registered",
      "accept_rate" : 81,
