    "content_license" : "CC BY-SA 3.0",
    "body" : "<pre><code>mvn source:jar\n</code></pre>\n\n<p>This is using the source:jar plugin <a href=\"http://maven.apache.org/plugins/maven-source-plugin/jar-mojo.html\" rel=\"noreferrer\">documentation</a></p>\n\n<p><a href=\"http://maven.apache.org/plugins/maven-source-plugin/usage.html\" rel=\"noreferrer\">Usage documentation</a></p>\n"
  }, {
    "owner" : {
      "account_id" : 159349,
      "reputation" : 1193,
      "user_id" : 378606,
      "user_type" : "registered",
