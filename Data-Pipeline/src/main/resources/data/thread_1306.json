      "content_license" : "CC BY-SA 4.0",
      "body" : "&quot;Modern&quot; syntax doesn&#39;t mean better. This can be done in 3 readable lines: List copy = new ArrayList(list);         Collections.reverse(copy);         copy = Collections.unmodifiableList(copy);"
    } ],
    "owner" : {
      "account_id" : 234754,
      "reputation" : 5955,
      "user_id" : 501113,
      "user_type" : "registered",
      "accept_rate" : 90,
      "profile_image" : "https://www.gravatar.com/avatar/3c66bc3a4bd1742ac9886eff6b6016dc?s=256&d=identicon&r=PG",
      "display_name" : "chaotic3quilibrium",
