    "owner" : {
      "account_id" : 10968388,
      "reputation" : 37068,
      "user_id" : 8059459,
      "user_type" : "registered",
      "accept_rate" : 90,
      "profile_image" : "https://www.gravatar.com/avatar/7a02411ebd47ea5e79243941d722057f?s=256&d=identicon&r=PG&f=y&so-version=2",
      "display_name" : "Willem van der Veen",
      "link" : "https://stackoverflow.com/users/8059459/willem-van-der-veen"
