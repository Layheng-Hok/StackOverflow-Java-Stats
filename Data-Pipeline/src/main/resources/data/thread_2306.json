    "owner" : {
      "account_id" : 4633327,
      "reputation" : 1587,
      "user_id" : 3755196,
      "user_type" : "registered",
      "accept_rate" : 50,
      "profile_image" : "https://i.sstatic.net/0aJ9G.jpg?s=256",
      "display_name" : "Raj Kumar",
      "link" : "https://stackoverflow.com/users/3755196/raj-kumar"
    },
    "is_accepted" : false,
