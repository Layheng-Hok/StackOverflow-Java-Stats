    "question_id" : 15336477,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>For the original issue, I would request you to apply below logic:</p>\n\n<pre><code> CloseableHttpClient httpClient = HttpClientBuilder.create().build();\n HttpPost httpPostRequest = new HttpPost();\n</code></pre>\n"
  }, {
    "owner" : {
      "account_id" : 332245,
      "reputation" : 17179,
      "user_id" : 657427,
      "user_type" : "registered",
      "accept_rate" : 67,
      "profile_image" : "https://www.gravatar.com/avatar/dd071a6a7c97ba637c558c5e71137c7b?s=256&d=identicon&r=PG",
      "display_name" : "Christophe Roussy",
      "link" : "https://stackoverflow.com/users/657427/christophe-roussy"
