    "body" : "<p>contrib..</p>\n<pre><code>List &lt;Destination\\&gt; destinations = Collections.nCopies(source.size(), Destination.class.newInstance());\n</code></pre>\n"
  }, {
    "owner" : {
      "account_id" : 12024687,
      "reputation" : 1839,
      "user_id" : 10249156,
      "user_type" : "registered",
      "profile_image" : "https://i.sstatic.net/26KWqncM.jpg?s=256",
      "display_name" : "Wasit Shafi",
      "link" : "https://stackoverflow.com/users/10249156/wasit-shafi"
