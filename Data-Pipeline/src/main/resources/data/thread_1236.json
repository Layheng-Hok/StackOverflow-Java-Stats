      "user_type" : "registered",
      "accept_rate" : 78,
      "profile_image" : "https://www.gravatar.com/avatar/1768cce8ccf2dffe3483b0ab5d7cfd74?s=256&d=identicon&r=PG",
      "display_name" : "Mnementh",
      "link" : "https://stackoverflow.com/users/21005/mnementh"
    },
