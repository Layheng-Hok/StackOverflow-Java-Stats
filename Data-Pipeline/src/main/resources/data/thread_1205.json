      "content_license" : "CC BY-SA 2.5",
      "body" : "Not only concrete and abstract subclasses, but also sub-interfaces: <code>List&lt;? extends Collection&lt;String&gt;&gt; list = new ArrayList&lt;List&lt;String&gt;&gt;();</code>."
    }, {
      "owner" : {
        "account_id" : 295869,
        "reputation" : 75003,
        "user_id" : 600500,
        "user_type" : "registered",
        "accept_rate" : 54,
        "profile_image" : "https://www.gravatar.com/avatar/5925786f174975db18cbc83dd85e5c1d?s=256&d=identicon&r=PG",
        "display_name" : "Paŭlo Ebermann",
        "link" : "https://stackoverflow.com/users/600500/pa%c5%adlo-ebermann"
      },
      "edited" : false,
