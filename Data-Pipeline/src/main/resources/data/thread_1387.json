      "edited" : false,
      "score" : 3,
      "creation_date" : 1409944874,
      "post_id" : 4185710,
      "comment_id" : 40157086,
      "content_license" : "CC BY-SA 3.0",
      "body" : "Probably better to ALTER the database itself so that the same user can connect to different databases with different search_paths if need be:  ALTER DATABASE dbname SET search_path TO public,schemaname;"
    } ],
    "owner" : {
      "account_id" : 67792,
