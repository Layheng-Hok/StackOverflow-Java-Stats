    "owner" : {
      "account_id" : 1622089,
      "reputation" : 18758,
      "user_id" : 1498427,
      "user_type" : "registered",
      "accept_rate" : 89,
      "profile_image" : "https://i.sstatic.net/cNxIm.png?s=256",
      "display_name" : "catch32",
      "link" : "https://stackoverflow.com/users/1498427/catch32"
    },
    "is_accepted" : false,
