    "body" : "<blockquote>\n  <p>Kotlin:</p>\n</blockquote>\n\n<pre><code>val selectedIndex = radioButtonGroup?.indexOfChild(\n  radioButtonGroup?.findViewById(\n    radioButtonGroup.getCheckedRadioButtonId())\n)\n</code></pre>\n"
  }, {
    "owner" : {
      "account_id" : 4020777,
      "reputation" : 1371,
      "user_id" : 3311219,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/f955689be0073f63d093f084465a37da?s=256&d=identicon&r=PG",
      "display_name" : "Tarek360",
      "link" : "https://stackoverflow.com/users/3311219/tarek360"
