      "user_type" : "registered",
      "accept_rate" : 61,
      "profile_image" : "https://www.gravatar.com/avatar/949d87a446a4ebe7e7370b0f58ba4692?s=256&d=identicon&r=PG&f=y&so-version=2",
      "display_name" : "Program-Me-Rev",
      "link" : "https://stackoverflow.com/users/3663765/program-me-rev"
    },
    "is_accepted" : false,
