      "display_name" : "user12231094"
    },
    "is_accepted" : false,
    "score" : 6,
    "last_activity_date" : 1583317668,
    "creation_date" : 1583317668,
    "answer_id" : 60523951,
    "question_id" : 37972859,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>Semantically there is no difference but for readability I prefer the following over <code>whatever == null</code>:</p>\n\n<pre><code>import static java.util.Objects.isNull;\n\n// Other stuff...\n\nif(isNull(whatever)) { \n\n}\n</code></pre>\n"
  } ],
