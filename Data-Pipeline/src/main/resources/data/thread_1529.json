      "user_type" : "registered",
      "accept_rate" : 100,
      "profile_image" : "https://www.gravatar.com/avatar/0dda88086f355af982bb0f26a409975d?s=256&d=identicon&r=PG",
      "display_name" : "Diego Lins de Freitas",
