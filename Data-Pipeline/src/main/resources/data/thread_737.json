    "answer_id" : 70181848,
    "question_id" : 1671378,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>I used this:</p>\n<pre><code>strs.isEmpty() ? &quot;&quot; : strs.iterator().next();\n</code></pre>\n<p>\uD83D\uDE04</p>\n"
  }, {
    "owner" : {
      "account_id" : 5914240,
      "reputation" : 2483,
      "user_id" : 4653517,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/cf72261d33ab65f0d5d0ecd8672403dd?s=256&d=identicon&r=PG",
      "display_name" : "James Mudd",
      "link" : "https://stackoverflow.com/users/4653517/james-mudd"
