      "content_license" : "CC BY-SA 3.0",
      "body" : "The whole point of Long.MIN_VAL is that you can&#39;t have a long that&#39;s &quot;less than LONG.MIN_VAL&quot;."
    } ],
    "owner" : {
      "account_id" : 713387,
      "reputation" : 27,
      "user_id" : 632733,
      "user_type" : "unregistered",
      "profile_image" : "https://www.gravatar.com/avatar/ba8daf64ca800470c9110538252cb77a?s=256&d=identicon&r=PG",
