    "body" : "<pre><code>if(arr[i]&lt;0)\n\nMath.abs(arr[i]);  //1st way (taking absolute value)\n\narr[i]=-(arr[i]); //2nd way (taking -ve of -ve no. yields a +ve no.)\n\narr[i]= ~(arr[i]-1);   //3rd way (taking negation)\n</code></pre>\n"
