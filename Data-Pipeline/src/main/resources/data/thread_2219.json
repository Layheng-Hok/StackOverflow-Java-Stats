    "owner" : {
      "account_id" : 1674383,
      "reputation" : 231,
      "user_id" : 1540221,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/1aec7431229f50dd92361e19a7ba1d51?s=256&d=identicon&r=PG",
      "display_name" : "Luan Vo",
      "link" : "https://stackoverflow.com/users/1540221/luan-vo"
