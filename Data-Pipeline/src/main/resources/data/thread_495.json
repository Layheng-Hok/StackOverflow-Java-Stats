    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>Nowadays Java seems to be installed in <code>/Library/Java/JavaVirtualMachines</code></p>\n"
  }, {
    "owner" : {
      "account_id" : 5158572,
      "reputation" : 457,
      "user_id" : 4131074,
      "user_type" : "registered",
      "profile_image" : "https://graph.facebook.com/100002864033885/picture?type=large",
