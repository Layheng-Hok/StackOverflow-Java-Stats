      "creation_date" : 1427473170,
      "post_id" : 27827221,
      "comment_id" : 46805169,
      "content_license" : "CC BY-SA 3.0",
      "body" : "It doesn&#39;t have to be final. See <a href=\"http://docs.oracle.com/javase/7/docs/technotes/guides/language/catch-multiple.html\" rel=\"nofollow noreferrer\">docs.oracle.com/javase/7/docs/technotes/guides/language/&hellip;</a> and <a href=\"http://stackoverflow.com/a/6889301/131160\">stackoverflow.com/a/6889301/131160</a>"
