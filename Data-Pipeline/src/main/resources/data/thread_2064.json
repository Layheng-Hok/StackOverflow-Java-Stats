      "content_license" : "CC BY-SA 3.0",
      "body" : "(For anyone coming across this question later, the given links are broken. The new ones are: <a href=\"http://docs.oracle.com/javase/specs/jls/se7/html/jls-4.html#jls-4.2.4\" rel=\"nofollow noreferrer\">docs.oracle.com/javase/specs/jls/se7/html/jls-4.html#jls-4.2&zwnj;&#8203;.4</a> and <a href=\"http://docs.oracle.com/javase/specs/jls/se7/html/jls-15.html#jls-15.17\" rel=\"nofollow noreferrer\">docs.oracle.com/javase/specs/jls/se7/html/jls-15.html#jls-15&zwnj;&#8203;.17</a>)"
    } ],
    "owner" : {
      "account_id" : 4495,
