      "user_type" : "registered",
      "accept_rate" : 93,
      "profile_image" : "https://i.sstatic.net/4zKq3.jpg?s=256",
      "display_name" : "AechoLiu",
      "link" : "https://stackoverflow.com/users/419348/aecholiu"
