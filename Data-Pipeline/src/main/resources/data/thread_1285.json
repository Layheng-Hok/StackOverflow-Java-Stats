      "content_license" : "CC BY-SA 4.0",
      "body" : "I too ended up doing something like this. I wasn&#39;t sure what kind of number I would receive and was willing to convert it to Long with little concern for efficiency but wanting to avoid boilerplate."
    } ],
    "owner" : {
      "account_id" : 619650,
      "reputation" : 29,
      "user_id" : 349951,
      "user_type" : "unregistered",
      "profile_image" : "https://www.gravatar.com/avatar/a34da62ba899e2288cb2eab8c1669d56?s=256&d=identicon&r=PG",
      "display_name" : "MaskedCoder",
