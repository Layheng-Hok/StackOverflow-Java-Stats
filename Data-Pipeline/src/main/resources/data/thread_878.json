      "comment_id" : 80493565,
      "content_license" : "CC BY-SA 3.0",
      "body" : "love this comment, using live templates this is for sure the fastest solution and most customisable (I removed the newline for example). To configure go to Android Studio &gt; Preferences &gt; Editor &gt; Live Templates and create a new one there (plus icon) with this value and use edit variables to enter the script"
    } ],
    "owner" : {
      "account_id" : 1081962,
      "reputation" : 807,
      "user_id" : 1078690,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/d6730248700194b0af5f4f553cb98c2d?s=256&d=identicon&r=PG",
