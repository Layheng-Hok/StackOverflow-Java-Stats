      "body" : "This is just a horrible way to do. So many things can go wrong depending on the implementation of the List (or Set, etc.)."
    }, {
      "owner" : {
        "account_id" : 6089055,
        "reputation" : 321,
        "user_id" : 4752024,
        "user_type" : "registered",
        "profile_image" : "https://i.sstatic.net/xMLG5.gif?s=256",
        "display_name" : "TheArchon",
