    "answer_id" : 8969117,
    "question_id" : 8969059,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<p><code>@ElementCollection</code> marks a collection. This does not necessarily mean that this collection references a 1-n join.</p>\n"
  }, {
    "comments" : [ {
      "owner" : {
        "account_id" : 291252,
