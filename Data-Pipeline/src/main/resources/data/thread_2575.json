    },
    "is_accepted" : false,
    "score" : 0,
    "last_activity_date" : 1764323791,
    "creation_date" : 1764323791,
    "answer_id" : 79832439,
    "question_id" : 18779183,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p><strong>IntelliJ IDEA: can not download sources</strong></p>\n<p>If you previously configured proxy settings in <code>settings.xml</code>(/Users/user/.m2/settings.xml) then check the connection to the proxy server. In my case, I had to switch on the VPN client to download sources</p>\n"
  } ],
