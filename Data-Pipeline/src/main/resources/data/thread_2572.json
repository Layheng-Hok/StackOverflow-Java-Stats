      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/aae10d930c8d060b1f89504598dca428?s=256&d=identicon&r=PG",
      "display_name" : "Frederic",
      "link" : "https://stackoverflow.com/users/18090829/frederic"
    },
