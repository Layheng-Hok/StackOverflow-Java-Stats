      "account_id" : 35074,
      "reputation" : 9357,
      "user_id" : 99248,
      "user_type" : "registered",
      "accept_rate" : 38,
      "profile_image" : "https://www.gravatar.com/avatar/44e6e0d2c563fd9da3dcf01e69e5d8f5?s=256&d=identicon&r=PG",
      "display_name" : "raisercostin",
      "link" : "https://stackoverflow.com/users/99248/raisercostin"
    },
    "is_accepted" : false,
