      "content_license" : "CC BY-SA 3.0",
      "body" : "This is the most performant answer by orders of magnitude and it even specifies what to do regarding the optional or not presence of the quotes."
    } ],
    "owner" : {
      "account_id" : 4467428,
      "reputation" : 822,
      "user_id" : 3634630,
      "user_type" : "registered",
      "accept_rate" : 80,
