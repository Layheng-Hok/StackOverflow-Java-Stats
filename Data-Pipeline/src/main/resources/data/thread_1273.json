    "score" : 13,
    "last_activity_date" : 1428089261,
    "creation_date" : 1428089261,
    "answer_id" : 29438460,
    "question_id" : 2973041,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<pre><code>import java.util.Map;\n\npublic class KeyValue&lt;K, V&gt; implements Map.Entry&lt;K, V&gt;\n{\n    private K key;\n    private V value;\n\n    public KeyValue(K key, V value)\n    {\n        this.key = key;\n        this.value = value;\n    }\n\n    public K getKey()\n    {\n        return this.key;\n    }\n\n    public V getValue()\n    {\n        return this.value;\n    }\n\n    public K setKey(K key)\n    {\n        return this.key = key;\n    }\n\n    public V setValue(V value)\n    {\n        return this.value = value;\n    }\n}\n</code></pre>\n"
  }, {
