    "answer_id" : 16532423,
    "question_id" : 957700,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>None of the solutions above worked for me (Eclipse Juno with JDK 1.7_015). Java could only find the libraries when I moved them from project_folder/lib to project_folder.</p>\n"
  }, {
    "owner" : {
      "account_id" : 2582692,
      "reputation" : 25,
      "user_id" : 2239018,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/a06da906fbbe18557749e3877bdaf5c5?s=256&d=identicon&r=PG",
      "display_name" : "vardhaman",
      "link" : "https://stackoverflow.com/users/2239018/vardhaman"
    },
    "is_accepted" : false,
