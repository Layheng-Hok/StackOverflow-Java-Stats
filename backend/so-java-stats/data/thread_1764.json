    "content_license" : "CC BY-SA 2.5",
    "body" : "<p><code>@Autowired</code> can be used with setters so you could have a setter modifying an static field.</p>\n\n<p>Just one final suggestion... <strong>DON'T</strong></p>\n"
  }, {
    "owner" : {
      "account_id" : 42845,
      "reputation" : 5338,
      "user_id" : 124982,
      "user_type" : "registered",
      "accept_rate" : 83,
      "profile_image" : "https://www.gravatar.com/avatar/f9f3a6247145340acb9c8bb450bfc901?s=256&d=identicon&r=PG",
      "display_name" : "JARC",
