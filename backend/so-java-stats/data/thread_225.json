      "user_type" : "registered",
      "accept_rate" : 67,
      "profile_image" : "https://www.gravatar.com/avatar/be86267e6e7ce47635626f06dcffe63e?s=256&d=identicon&r=PG",
      "display_name" : "Andy Guibert",
