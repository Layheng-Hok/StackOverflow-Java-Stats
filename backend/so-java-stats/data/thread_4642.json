      "comment_id" : 138265609,
      "content_license" : "CC BY-SA 4.0",
      "body" : "This advice (combined with <a href=\"https://stackoverflow.com/a/59108464/2171120\">this comment</a>) fixes the bug introduced by <a href=\"https://issues.apache.org/jira/browse/SUREFIRE-951\" rel=\"nofollow noreferrer\">this bugfix</a>… <i>sigh</i>"
    } ],
    "owner" : {
      "account_id" : 13803571,
      "reputation" : 109,
      "user_id" : 9963016,
      "user_type" : "registered",
      "profile_image" : "https://lh5.googleusercontent.com/-vyVICwvJpIs/AAAAAAAAAAI/AAAAAAAAAsI/wDKOeMS6Q5s/s256-rj/photo.jpg",
      "display_name" : "swapnil kadam",
      "link" : "https://stackoverflow.com/users/9963016/swapnil-kadam"
    },
    "is_accepted" : false,
    "score" : 2,
    "last_activity_date" : 1704782773,
    "creation_date" : 1704782773,
    "answer_id" : 77784803,
    "question_id" : 17656475,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p><strong>Following works for me without any issues:</strong></p>\n<pre><code>       &lt;plugin&gt;\n          &lt;groupId&gt;org.apache.maven.plugins&lt;/groupId&gt;\n          &lt;artifactId&gt;maven-surefire-plugin&lt;/artifactId&gt;\n          &lt;version&gt;3.1.0&lt;/version&gt;\n          &lt;configuration&gt;\n            &lt;test&gt;com.testsuite.JunitTestSuite&lt;/test&gt;\n            &lt;argLine&gt;${argLine} -Dfile.encoding=UTF-8&lt;/argLine&gt;\n          &lt;/configuration&gt;\n        &lt;/plugin&gt;\n</code></pre>\n"
  } ],
