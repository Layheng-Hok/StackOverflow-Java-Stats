    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>This also works in Java 8 :</p>\n\n<pre><code>Path file = Paths.get(\"Some path\");\nfile = Paths.get(file + \"Some other path\");\n</code></pre>\n"
  }, {
    "owner" : {
      "account_id" : 5891068,
      "reputation" : 266,
      "user_id" : 4637676,
      "user_type" : "registered",
      "profile_image" : "https://i.sstatic.net/T4D7w.jpg?s=256",
