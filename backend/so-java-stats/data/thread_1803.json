      "comment_id" : 58950543,
      "content_license" : "CC BY-SA 3.0",
      "body" : "It looks like the intention is that you reference the kits directly, and they pull in the io.fabric.sdk.android classes via transitive dependency."
    } ],
    "owner" : {
      "account_id" : 944074,
      "reputation" : 40784,
      "user_id" : 971684,
      "user_type" : "registered",
      "accept_rate" : 100,
      "profile_image" : "https://www.gravatar.com/avatar/4a6f0b507654f2d6903dbe25a2917982?s=256&d=identicon&r=PG",
      "display_name" : "Sam Dozor",
