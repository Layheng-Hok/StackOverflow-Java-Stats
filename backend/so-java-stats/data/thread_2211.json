      "body" : "You can use ExecutorService class instead of Executor. It has shutdown() method to stop the executor."
    }, {
      "owner" : {
        "account_id" : 40279,
        "reputation" : 4035,
        "user_id" : 116718,
        "user_type" : "registered",
        "profile_image" : "https://i.sstatic.net/srfwy.jpg?s=256",
        "display_name" : "adam",
