      "content_license" : "CC BY-SA 4.0",
      "body" : "Update for recent Homebrew builds: <code>sudo ln -sfn &#47;opt&#47;homebrew&#47;Cellar&#47;openjdk&#47;19.0.2&#47;libexec&#47;openjdk.jdk &#47;Library&#47;Java&#47;JavaVirtualMachines&#47;openjdk.jdk</code>"
    } ],
    "owner" : {
      "account_id" : 9183606,
      "reputation" : 155,
      "user_id" : 6826659,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/c7a713a79b97bc8b5426be178634cfaa?s=256&d=identicon&r=PG&f=y&so-version=2",
      "display_name" : "Gerard",
