      "creation_date" : 1535709569,
      "post_id" : 52112835,
      "comment_id" : 91176407,
      "content_license" : "CC BY-SA 4.0",
      "body" : "using the following code solved my doubt: <code>Class child_super = c1.getSuperclass(); \t      System.out.println(child_super.getSuperclass());</code>"
    } ],
    "owner" : {
      "account_id" : 2133309,
      "reputation" : 2592,
      "user_id" : 7671876,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/515973f381fe3ebc5a1052ee34b57127?s=256&d=identicon&r=PG&f=y&so-version=2",
      "display_name" : "codeLover",
