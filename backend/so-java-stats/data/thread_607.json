    "question_id" : 9966053,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<p><code>[]</code> is replaced by <code>%5B%5D</code> at URL encoding time.</p>\n"
  }, {
    "owner" : {
      "account_id" : 200320,
      "reputation" : 3826,
      "user_id" : 446106,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/f85c140d1efdc501c26c0e911c6bd5d0?s=256&d=identicon&r=PG",
      "display_name" : "mwfearnley",
