      "user_type" : "registered",
      "accept_rate" : 80,
      "profile_image" : "https://www.gravatar.com/avatar/7e12d84a1f74d9acd8afab1d679aca89?s=256&d=identicon&r=PG",
      "display_name" : "ManoDestra",
      "link" : "https://stackoverflow.com/users/5969411/manodestra"
