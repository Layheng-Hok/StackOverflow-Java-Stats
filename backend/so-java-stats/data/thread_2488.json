    "answer_id" : 61278726,
    "question_id" : 3631110,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>This works:</p>\n\n<pre><code>assertThat(list,IsEmptyCollection.empty())\n</code></pre>\n"
