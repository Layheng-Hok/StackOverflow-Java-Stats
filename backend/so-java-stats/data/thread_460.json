      "accept_rate" : 43,
      "profile_image" : "https://www.gravatar.com/avatar/99995fa9acbce700beeba72890c1c9ea?s=256&d=identicon&r=PG",
      "display_name" : "Genjuro",
      "link" : "https://stackoverflow.com/users/978769/genjuro"
    },
    "is_accepted" : false,
