    "answer_id" : 4030999,
    "question_id" : 4030928,
    "content_license" : "CC BY-SA 2.5",
    "body" : "<pre><code>public String extractDigits(String src) {\n    StringBuilder builder = new StringBuilder();\n    for (int i = 0; i &lt; src.length(); i++) {\n        char c = src.charAt(i);\n        if (Character.isDigit(c)) {\n            builder.append(c);\n        }\n    }\n    return builder.toString();\n}\n</code></pre>\n"
  }, {
    "comments" : [ {
      "owner" : {
        "account_id" : 15188,
