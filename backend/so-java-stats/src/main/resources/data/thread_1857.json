      "comment_id" : 117691405,
      "content_license" : "CC BY-SA 4.0",
      "body" : "Indeed, I had a JDK version 11 and project language level 9. Setting them both the same cleared the error."
    } ],
    "owner" : {
      "account_id" : 2287887,
      "reputation" : 3614,
      "user_id" : 2011505,
      "user_type" : "registered",
      "accept_rate" : 83,
      "profile_image" : "https://i.sstatic.net/2TB97eM6.jpg?s=256",
      "display_name" : "Tharkius",
