    },
    "is_accepted" : false,
    "score" : 4,
    "last_activity_date" : 1675654651,
    "creation_date" : 1675654651,
    "answer_id" : 75357125,
    "question_id" : 8367312,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>Adding a getter/setter solved this problem for me.\neither manually add getter/setter or use Lombok annotations @Getter/@Setter/@Data for the same.</p>\n"
  }, {
    "owner" : {
      "account_id" : 28438417,
      "reputation" : 51,
      "user_id" : 21758160,
      "user_type" : "registered",
