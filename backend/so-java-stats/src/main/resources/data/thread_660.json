    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>in spring boot 2.2.5</p>\n\n<p>after adding getter and setter </p>\n\n<p>i added @JsonIgnore on top of the field.</p>\n"
  }, {
    "owner" : {
      "account_id" : 2270908,
      "reputation" : 3393,
      "user_id" : 2313177,
      "user_type" : "registered",
      "accept_rate" : 59,
      "profile_image" : "https://i.sstatic.net/oZqOH.jpg?s=256",
      "display_name" : "Andriy Kryvtsun",
