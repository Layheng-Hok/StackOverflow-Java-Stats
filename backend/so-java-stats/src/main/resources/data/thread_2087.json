    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>You can use addAll().</p>\n\n<p>eg : <code>wsListCopy.addAll(wsList);</code></p>\n"
  }, {
    "owner" : {
      "account_id" : 3155790,
      "reputation" : 16526,
      "user_id" : 2668232,
      "user_type" : "registered",
      "accept_rate" : 100,
      "profile_image" : "https://i.sstatic.net/Ngw4G.jpg?s=256",
