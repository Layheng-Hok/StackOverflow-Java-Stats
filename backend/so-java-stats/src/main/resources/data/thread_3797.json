    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>On Mac OS X:</p>\n\n<pre><code>/Applications/NetBeans/NetBeans XXX.app/Contents/Resources/NetBeans/etc/netbeans.conf\n</code></pre>\n\n<p>(Where XXX is The installed version of NetBeans)</p>\n\n<p>Example for NetBeans 8.0:</p>\n\n<pre><code>/Applications/NetBeans/NetBeans 8.0.app/Contents/Resources/NetBeans/etc/netbeans.conf\n</code></pre>\n"
  }, {
    "owner" : {
      "account_id" : 64734,
      "reputation" : 1538,
      "user_id" : 190955,
      "user_type" : "registered",
      "accept_rate" : 78,
      "profile_image" : "https://www.gravatar.com/avatar/95ec74c941e5a819f61c02e1d7a2b0a7?s=256&d=identicon&r=PG",
      "display_name" : "TonyG",
