    "question_id" : 4323599,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>This would do the job:</p>\n\n<pre><code>Double.parseDouble(p.replace(',','.')); \n</code></pre>\n"
  }, {
    "owner" : {
      "account_id" : 9958991,
      "reputation" : 225,
      "user_id" : 7368903,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/539a8e114839dc48987fa46c4659c964?s=256&d=identicon&r=PG&f=y&so-version=2",
      "display_name" : "RocketBanana",
