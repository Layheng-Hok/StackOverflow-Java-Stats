      "accept_rate" : 89,
      "profile_image" : "https://www.gravatar.com/avatar/60e3c03e227b84e2898c29fd711cae5b?s=256&d=identicon&r=PG",
      "display_name" : "Mark Bolusmjak",
      "link" : "https://stackoverflow.com/users/131227/mark-bolusmjak"
