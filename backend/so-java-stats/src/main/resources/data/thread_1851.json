        "profile_image" : "https://www.gravatar.com/avatar/1b949fe444f6b58739dcbc54b12f8235?s=256&d=identicon&r=PG&f=y&so-version=2",
        "display_name" : "Charles Roth",
        "link" : "https://stackoverflow.com/users/3645968/charles-roth"
