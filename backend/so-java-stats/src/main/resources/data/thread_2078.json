      "comment_id" : 139087214,
      "content_license" : "CC BY-SA 4.0",
      "body" : "This sounds nice because you could directly enter the Locale of your preference, but in my case (Java8 on macOS) it returned the numbers formatted in US-Style (1,000.00). Therefore I stick to this answer <a href=\"https://stackoverflow.com/a/56831492/9064287\">stackoverflow.com/a/56831492/9064287</a> with some post-editing (replace)"
    } ],
    "owner" : {
      "account_id" : 12522268,
      "reputation" : 71,
      "user_id" : 10936399,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/0f819583e5038eabbb719067ec7f0c3f?s=256&d=identicon&r=PG&f=y&so-version=2",
      "display_name" : "0xjacobb",
