    "question_id" : 47835901,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>A Spring Boot project configured through Maven can be run using the following command from the project source folder</p>\n\n<pre><code>mvn spring-boot:run\n</code></pre>\n"
  }, {
    "owner" : {
      "account_id" : 5096768,
