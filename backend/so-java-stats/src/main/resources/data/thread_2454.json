      "content_license" : "CC BY-SA 4.0",
      "body" : "Why do interfaces need this special treatment? Wouldn&#39;t it have been simpler to inherit from Object like everything else?"
    } ],
    "owner" : {
      "account_id" : 102965,
      "reputation" : 422600,
      "user_id" : 276052,
      "user_type" : "registered",
      "accept_rate" : 80,
      "profile_image" : "https://i.sstatic.net/UcrhR.jpg?s=256",
      "display_name" : "aioobe",
