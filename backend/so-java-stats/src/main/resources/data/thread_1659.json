    "answer_id" : 78547787,
    "question_id" : 5600668,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>Using Java 8 Stream:</p>\n<pre><code>Stream.generate(() -&gt; 0).limit(10).collect(Collectors.toList());\n</code></pre>\n"
  } ],
