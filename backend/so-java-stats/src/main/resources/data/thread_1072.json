    "answer_id" : 45489101,
    "question_id" : 8898590,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>Use org.apache.commons.lang3.StringUtils:</p>\n\n<pre><code>name = StringUtils.defaultString(city.getName(), \"N/A\");\n</code></pre>\n"
  }, {
    "owner" : {
