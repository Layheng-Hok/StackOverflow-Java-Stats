        "user_type" : "registered",
        "profile_image" : "https://www.gravatar.com/avatar/c46163c3ff70536db687ab0bee71af46?s=256&d=identicon&r=PG",
        "display_name" : "jonashackt",
        "link" : "https://stackoverflow.com/users/4964553/jonashackt"
      },
      "edited" : false,
