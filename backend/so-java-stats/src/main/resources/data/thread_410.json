    "answer_id" : 27438084,
    "question_id" : 12900373,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>I resolved bellow method</p>\n\n<p>File >> Project Structure >> Project >> Project Language Level\n --> do set proper version (ex: 1.5)</p>\n"
  }, {
    "owner" : {
      "account_id" : 3946480,
      "reputation" : 1251,
      "user_id" : 3258879,
      "user_type" : "registered",
      "accept_rate" : 44,
      "profile_image" : "https://www.gravatar.com/avatar/6d032b68b04d9f77020f36622b61bf18?s=256&d=identicon&r=PG&f=y&so-version=2",
      "display_name" : "Robert",
