    "owner" : {
      "account_id" : 54451,
      "reputation" : 8906,
      "user_id" : 162895,
      "user_type" : "registered",
      "accept_rate" : 100,
      "profile_image" : "https://www.gravatar.com/avatar/da3b58702a60fd2681ece7edddec2ccd?s=256&d=identicon&r=PG",
      "display_name" : "Dimitris Andreou",
      "link" : "https://stackoverflow.com/users/162895/dimitris-andreou"
    },
    "is_accepted" : false,
