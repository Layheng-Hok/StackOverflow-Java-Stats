      "post_id" : 30403346,
      "comment_id" : 102997573,
      "content_license" : "CC BY-SA 4.0",
      "body" : "its now 2019 and this is STILL an issue!  Except its slightly different and the variable at fault is now &quot;set JAVA_EXE=%JAVA_HOME%/bin/java.exe&quot; - remove the bin part from here to fix."
    } ],
    "owner" : {
      "account_id" : 217163,
      "reputation" : 399,
      "user_id" : 472832,
      "user_type" : "registered",
      "accept_rate" : 59,
      "profile_image" : "https://www.gravatar.com/avatar/f4ac082f29d8ba205dfb70aa48113984?s=256&d=identicon&r=PG",
      "display_name" : "asp_NewBee",
