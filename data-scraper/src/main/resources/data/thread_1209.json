      "user_type" : "registered",
      "accept_rate" : 63,
      "profile_image" : "https://www.gravatar.com/avatar/70460c7edbf59037487fc1d9a285c307?s=256&d=identicon&r=PG",
      "display_name" : "Tom B",
      "link" : "https://stackoverflow.com/users/471227/tom-b"
