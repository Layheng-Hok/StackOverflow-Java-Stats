      "post_id" : 55350537,
      "comment_id" : 128958141,
      "content_license" : "CC BY-SA 4.0",
      "body" : "1.) You allocate a thread pool with multiple threads while you only need one. 2.) You don&#39;t shut down your executor. Every executor should be properly shut down, otherwise its threads will run forever."
    } ],
    "owner" : {
      "account_id" : 15110421,
      "reputation" : 117,
      "user_id" : 10904724,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/5b5950036a4ed8b5ac619c1ff90684b8?s=256&d=identicon&r=PG&f=y&so-version=2",
      "display_name" : "Anand",
