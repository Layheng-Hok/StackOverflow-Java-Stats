      "content_license" : "CC BY-SA 3.0",
      "body" : "The other solutions all create new strings or lists or just handle single elements. Guava&#39;s Chars.indexOf lets you get the index of an array in an array. This is the correct solution."
    } ],
    "owner" : {
      "account_id" : 21620,
      "reputation" : 2681,
