    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>$ whereis java</p>\n\n<p>java: /usr/bin/java /usr/lib/java /usr/bin/X11/java /usr/share/java   /usr/share/man/man1/java.1.gz</p>\n"
