    "answer_id" : 71047517,
    "question_id" : 11474729,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>Android:</p>\n<pre><code>  task androidSourcesJar(type: Jar) {\n        getArchiveClassifier().set('sources')\n        from android.sourceSets.main.java.srcDirs//full sources\n  }\n</code></pre>\n<p>Java:</p>\n<pre><code> task sourcesJar(type: Jar, dependsOn: classes) {\n        getArchiveClassifier().set('sources')\n        from sourceSets.main.allSource\n    }\n</code></pre>\n"
  } ],
