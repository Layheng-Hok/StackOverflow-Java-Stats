    "question_id" : 4830253,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>If you have Android installed in windows, you will also find it here:\nC:\\Program Files\\Android\\jdk\\microsoft_dist_openjdk_1.8.0.25\\jre\\bin</p>\n"
  }, {
    "owner" : {
      "account_id" : 18225812,
      "reputation" : 345,
      "user_id" : 13265630,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/52171d2ee57d83eb914178c12cbbc695?s=256&d=identicon&r=PG",
