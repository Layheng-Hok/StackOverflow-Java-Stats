    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>A visual for those that benefit from it.</p>\n\n<p><a href=\"https://i.sstatic.net/3GCAR.png\" rel=\"noreferrer\"><img src=\"https://i.sstatic.net/3GCAR.png\" alt=\"enter image description here\"></a></p>\n\n<p>After right-clicking the project name (\"test\" in this example), select \"Add framework support\" and check the \"Maven\" option. </p>\n"
  }, {
    "owner" : {
      "account_id" : 2152669,
      "reputation" : 1762,
      "user_id" : 1945316,
      "user_type" : "registered",
      "accept_rate" : 18,
      "profile_image" : "https://www.gravatar.com/avatar/aec50f6ea348ca30f5b77d868d038944?s=256&d=identicon&r=PG",
      "display_name" : "Thomas",
      "link" : "https://stackoverflow.com/users/1945316/thomas"
    },
    "is_accepted" : false,
    "score" : 7,
    "last_activity_date" : 1574704015,
    "last_edit_date" : 1574704015,
    "creation_date" : 1491549907,
