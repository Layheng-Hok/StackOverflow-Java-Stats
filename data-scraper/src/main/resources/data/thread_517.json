    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>This fixed it for me: Open maven projects tab on the right. Add the pom if not yet present, then click refresh on the top left of the tab.</p>\n"
  }, {
    "owner" : {
      "account_id" : 4910831,
      "reputation" : 490,
      "user_id" : 3956183,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/630ac0ff211147e2dc8cc1ec6d4d0442?s=256&d=identicon&r=PG&f=y&so-version=2",
      "display_name" : "LostMage",
