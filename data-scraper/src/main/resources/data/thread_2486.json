    },
    "is_accepted" : false,
    "score" : 22,
    "last_activity_date" : 1566467755,
    "creation_date" : 1566467755,
    "answer_id" : 57606669,
    "question_id" : 31211842,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>Can't import all at once but can use following combination:</p>\n\n<p><code>ALT</code> + <code>Enter</code> -->  Show intention actions and quick-fixes.</p>\n\n<p><code>F2</code>            -->  Next highlighted error. </p>\n"
  }, {
    "owner" : {
      "account_id" : 6597861,
      "reputation" : 7718,
      "user_id" : 5097027,
      "user_type" : "registered",
      "accept_rate" : 71,
      "profile_image" : "https://i.sstatic.net/YqLt4.jpg?s=256",
      "display_name" : "NarendraR",
