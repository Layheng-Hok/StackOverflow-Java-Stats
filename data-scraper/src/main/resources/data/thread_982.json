    "creation_date" : 1499733389,
    "answer_id" : 45023592,
    "question_id" : 1945213,
    "content_license" : "CC BY-SA 3.0",
    "body" : "<p>It is possible to use eclipse keymap in intellij by clicking <kbd>ALT</kbd>+ <kbd>→</kbd> keymap. Then select eclipse keymap.</p>\n"
  }, {
    "owner" : {
      "account_id" : 2890494,
      "reputation" : 51,
      "user_id" : 2479398,
      "user_type" : "registered",
      "profile_image" : "https://www.gravatar.com/avatar/604a99c2d8d17bb99100c9f956736c84?s=256&d=identicon&r=PG",
