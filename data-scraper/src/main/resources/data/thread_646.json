      "user_type" : "registered",
      "accept_rate" : 73,
      "profile_image" : "https://www.gravatar.com/avatar/c56c0fff4035826235a65ec607cacb97?s=256&d=identicon&r=PG",
      "display_name" : "Fernando Migu&#233;lez",
      "link" : "https://stackoverflow.com/users/34880/fernando-migu%c3%a9lez"
    },
    "is_accepted" : false,
