    "last_activity_date" : 1761982618,
    "creation_date" : 1761982618,
    "answer_id" : 79806387,
    "question_id" : 54381689,
    "content_license" : "CC BY-SA 4.0",
    "body" : "<p>Since MapStruct 1.6 you can use annotation</p>\n<pre class=\"lang-java prettyprint-override\"><code>@AnnotateWith(value = Profile.class, \n    elements = { @Element(name = &quot;value&quot;, strings = &quot;dev&quot;) })\n</code></pre>\n"
  } ],
