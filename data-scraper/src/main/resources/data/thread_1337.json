      "post_id" : 65632066,
      "comment_id" : 122617004,
      "content_license" : "CC BY-SA 4.0",
      "body" : "For my case I am using Java 11 but was accidentally on jdk14, so this helped! To change: File -&gt; Project Structure -&gt; Project SDK"
    } ],
    "owner" : {
      "account_id" : 16774134,
