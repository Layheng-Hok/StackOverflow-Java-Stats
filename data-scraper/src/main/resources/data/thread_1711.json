      "user_type" : "unregistered",
      "profile_image" : "https://www.gravatar.com/avatar/2aa1f740db86f224d4cfcd56acbbac57?s=256&d=identicon&r=PG",
      "display_name" : "Marcos vitouley",
      "link" : "https://stackoverflow.com/users/10817676/marcos-vitouley"
    },
    "is_accepted" : false,
